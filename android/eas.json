{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "VIBEZEN_API_URL": "http://10.0.2.2:5000",
        "VIBEZEN_WEB_URL": "http://10.0.2.2:4200"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "VIBEZEN_API_URL": "https://api.vibezen.example",
        "VIBEZEN_WEB_URL": "https://app.vibezen.example"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "VIBEZEN_API_URL": "https://api.vibezen.example",
        "VIBEZEN_WEB_URL": "https://app.vibezen.example"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
